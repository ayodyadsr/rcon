    git clone --depth 1 https://github.com/m4ll0k/SecretFinder.git "$SECRETFINDER_DIR" &>/dev/null
    if [[ -f "$SECRETFINDER_DIR/requirements.txt" ]]; then
        pip3 install --break-system-packages -r "$SECRETFINDER_DIR/requirements.txt" &>/dev/null
