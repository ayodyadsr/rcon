#!/bin/bash
#
# rcon - Full recon workflow, mendukung 2 mode scan:
#
#   SCAN_MODE=wildcard (default) : targets.txt isi ROOT DOMAIN, full enum
#                                  (subfinder+amass+crt.sh+permutation+resolve)
#                                  -> excludes.txt OPSIONAL, buat filter subdomain out-of-scope
#
#   SCAN_MODE=targeted           : targets.txt isi SUBDOMAIN/HOST SPESIFIK yang mau di-scan
#                                  langsung (skip enum & permutation sepenuhnya)
#                                  -> excludes.txt OPSIONAL, biasanya gak perlu krn udah presisi
#
# Usage:
#   SCAN_MODE=wildcard  ./rcon targets.txt [excludes.txt]
#   SCAN_MODE=targeted  ./rcon targets.txt [excludes.txt]
#
# Env override (opsional):
#   SCAN_MODE               - wildcard | targeted (default: wildcard)
#   EXTRA_PORTS              - daftar port httpx
#   HTTPX_RATE               - rate limit httpx (default: 150)
#   HTTPX_THREADS            - jumlah thread httpx (default: 50)
#   DNSX_THREADS             - jumlah thread dnsx (default: 100)
#   KATANA_HEADLESS_LIMIT    - maks jumlah host yang di-headless-crawl (default: 20)
#
# CATATAN: dnsx & katana TIDAK dibatasi waktu keseluruhan (bakal jalan sampai tuntas).
#          Per-request timeout tetap aktif (dnsx: 5s, katana static: 10s, headless: 15s)
#          supaya SATU item yang nyangkut gak bikin SELURUH proses hang selamanya.
#
set -uo pipefail

print_usage() {
cat << 'USAGE_EOF'
rcon - Full recon workflow (subdomain enum -> resolve -> live check -> URL mining -> screenshot)

USAGE:
  ./rcon [-h|--help] [--log|-L <file>] [targets.txt] [excludes.txt]

FLAG:
  -h, --help              Tampilkan bantuan ini
  --log, --log-file, -L, -l <file>
                          Simpan SEMUA output (stdout+stderr) ke <file> juga (via tee),
                          selain tetap tampil di terminal. Kalau flag ini TIDAK dipakai,
                          log cuma tampil di terminal seperti biasa (gak disimpan otomatis).
                          Berguna kalau log kepanjangan & scrollback terminal kepotong —
                          buka file log-nya pakai 'tail -f <file>' atau 'less +F <file>'
                          dari terminal lain, bisa scroll/cari bebas tanpa batas.

ARGUMEN POSISI:
  targets.txt    (opsional, default: targets.txt)
                 - Mode wildcard : isi ROOT DOMAIN (contoh: nubank.com.br)
                 - Mode targeted : isi SUBDOMAIN/HOST SPESIFIK (contoh: app.nubank.com.br)
  excludes.txt   (opsional, default: excludes.txt)
                 - Pattern (substring) yang mau di-exclude dari hasil enum, 1 per baris
                 - Kalau file tidak ada/kosong, semua hasil enum diproses (tidak ada yg di-exclude)

MODE SCAN (via env var SCAN_MODE):
  SCAN_MODE=wildcard   (default) Full enum: subfinder+amass+crt.sh+permutation+resolve
  SCAN_MODE=targeted   Skip enum & permutation, langsung scan host yang ada di targets.txt

ENV VAR OPSIONAL LAINNYA:
  EXTRA_PORTS            Daftar port httpx, comma-separated (default: list panjang port umum)
  HTTPX_RATE             Rate limit httpx, request/detik (default: 150)
  HTTPX_THREADS          Jumlah thread httpx (default: 50)
  DNSX_THREADS           Jumlah thread dnsx (default: 100)
  KATANA_HEADLESS_LIMIT  Maks jumlah host yang di-headless-crawl (default: 20)

CATATAN WAKTU:
  dnsx & katana TIDAK dibatasi waktu keseluruhan (jalan sampai tuntas).
  Per-request timeout tetap aktif (dnsx: 5s, katana static: 10s, headless: 15s)
  supaya SATU item yang nyangkut gak bikin SELURUH proses hang selamanya.

CONTOH:
  # Wildcard + exclude list
  SCAN_MODE=wildcard ./rcon targets.txt excludes.txt

  # Wildcard tanpa exclude
  SCAN_MODE=wildcard ./rcon targets.txt

  # Targeted (host spesifik, skip enum)
  SCAN_MODE=targeted ./rcon targets_specific.txt

  # Custom port + rate limit lebih pelan
  HTTPX_RATE=50 EXTRA_PORTS="80,443,8443" ./rcon targets.txt excludes.txt

  # Simpan log ke file (biar bisa di-tail/less dari terminal lain, gak kepotong scrollback)
  ./rcon --log recon_run.log targets.txt excludes.txt

OUTPUT:
  Semua hasil disimpan di folder recon_<timestamp>/, termasuk report.md
  yang berisi ringkasan angka + host paling menarik utk direview duluan.
USAGE_EOF
}

for arg in "$@"; do
    if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
        print_usage
        exit 0
    fi
done

# ---------- ARGUMENT PARSING (support flag --log/-L, sisanya positional) ----------
LOG_FILE=""
POSITIONAL=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --log|--log-file|-L|-l)
            if [[ -z "${2:-}" ]]; then
                echo "Error: $1 butuh argumen path file, contoh: $1 output.log"
                exit 1
            fi
            LOG_FILE="$2"
            shift 2
            ;;
        *)
            POSITIONAL+=("$1")
            shift
            ;;
    esac
done
set -- "${POSITIONAL[@]:-}"

TARGET_FILE="${1:-targets.txt}"
EXCLUDE_FILE="${2:-excludes.txt}"
SCAN_MODE="${SCAN_MODE:-wildcard}"
OUTDIR="recon_$(date +%Y%m%d_%H%M%S)"
GOBIN="${GOPATH:-$HOME/go}/bin"
export PATH="$PATH:$GOBIN"

RESOLVERS_URL="${RESOLVERS_URL:-https://raw.githubusercontent.com/trickest/resolvers/main/resolvers-trusted.txt}"
HTTPX_RATE="${HTTPX_RATE:-150}"
HTTPX_THREADS="${HTTPX_THREADS:-50}"
DNSX_THREADS="${DNSX_THREADS:-100}"
KATANA_HEADLESS_LIMIT="${KATANA_HEADLESS_LIMIT:-20}"

if [[ "$SCAN_MODE" != "wildcard" && "$SCAN_MODE" != "targeted" ]]; then
    echo "SCAN_MODE harus 'wildcard' atau 'targeted', bukan '$SCAN_MODE'"
    exit 1
fi

# ---------- TIMESTAMP & PROGRESS TRACKING ----------
SCRIPT_START_EPOCH=$(date +%s)
CURRENT_STAGE=0
TOTAL_STAGES=10
LAST_STAGE_START=$SCRIPT_START_EPOCH

ts() { date '+%Y-%m-%d %H:%M:%S'; }

fmt_duration() {
    local total="$1"
    printf '%02dh:%02dm:%02ds' $((total/3600)) $(((total%3600)/60)) $((total%60))
}

elapsed_since_start() {
    local now; now=$(date +%s)
    fmt_duration $(( now - SCRIPT_START_EPOCH ))
}

log() { echo -e "[$(ts)] \033[1;34m[*]\033[0m $1"; }
ok()  { echo -e "[$(ts)] \033[1;32m[+]\033[0m $1"; }
err() { echo -e "[$(ts)] \033[1;31m[-]\033[0m $1"; }
warn(){ echo -e "[$(ts)] \033[1;33m[!]\033[0m $1"; }

# stage <deskripsi> - dipanggil di awal tiap stage utama (1-9).
# Otomatis print: durasi stage sebelumnya, nomor stage & persentase, total elapsed, dan estimasi sisa waktu.
# CATATAN: estimasi sisa waktu ini KASAR (rata-rata durasi stage yg udah lewat x sisa stage).
# Gak akurat kalau stage yg beda punya karakter durasi jauh berbeda (mis. enum cepat tapi katana lama) -
# terutama di awal proses. Anggap ini sekedar gambaran, bukan janji waktu pasti.
stage() {
    local now; now=$(date +%s)
    if [[ "$CURRENT_STAGE" -gt 0 ]]; then
        echo -e "[$(ts)] \033[1;35m[DURASI]\033[0m Stage $CURRENT_STAGE selesai dalam $(fmt_duration $(( now - LAST_STAGE_START )))"
    fi
    CURRENT_STAGE=$((CURRENT_STAGE+1))
    LAST_STAGE_START=$now
    local pct=$(( (CURRENT_STAGE-1) * 100 / TOTAL_STAGES ))
    local elapsed=$(( now - SCRIPT_START_EPOCH ))
    local eta_str="belum bisa diestimasi"
    if [[ "$CURRENT_STAGE" -gt 1 ]]; then
        local completed=$(( CURRENT_STAGE - 1 ))
        local avg=$(( elapsed / completed ))
        local remaining=$(( TOTAL_STAGES - completed ))
        local eta=$(( avg * remaining ))
        eta_str="~$(fmt_duration $eta) (estimasi KASAR)"
    fi
    echo -e "[$(ts)] \033[1;36m[STAGE $CURRENT_STAGE/$TOTAL_STAGES — progress: ${pct}%]\033[0m $1"
    echo -e "[$(ts)] \033[1;36m           elapsed: $(fmt_duration $elapsed) | estimasi sisa: $eta_str\033[0m"
}

check_or_install() {
    local bin_name="$1"; local install_cmd="$2"
    if command -v "$bin_name" &>/dev/null; then
        ok "$bin_name sudah terinstall ($(command -v "$bin_name"))"
    else
        log "$bin_name belum ada, mencoba install..."
        eval "$install_cmd"
        command -v "$bin_name" &>/dev/null && ok "$bin_name berhasil diinstall" || warn "Gagal install $bin_name — tahap terkait akan di-skip"
    fi
}

apply_exclude() {
    local infile="$1"; local outfile="$2"
    if [[ -f "$EXCLUDE_FILE" && -s "$EXCLUDE_FILE" ]]; then
        grep -vif "$EXCLUDE_FILE" "$infile" > "$outfile" 2>/dev/null || cp "$infile" "$outfile"
    else
        cp "$infile" "$outfile"
    fi
}

# heartbeat_monitor <file_output> <total_target> <label> - jalan di background,
# print progress tiap 60 detik selagi proses utama (mis. dnsx) masih jalan.
# Bukan pengganti timeout — cuma kasih tau "masih hidup, progressnya segini",
# biar gak was-was pas nunggu proses yang makan waktu lama.
heartbeat_monitor() {
    local file="$1"; local total="$2"; local label="$3"
    while true; do
        sleep 60
        local current; current=$(cat "$file" 2>/dev/null | wc -l)
        local pct=0
        [[ "$total" -gt 0 ]] && pct=$(( current * 100 / total ))
        echo -e "[$(ts)] \033[1;33m[HEARTBEAT]\033[0m $label masih jalan... progress: $current/$total baris (~${pct}%)"
    done
}

# simple_heartbeat <label> [interval_detik] - versi tanpa file counter, buat tool yang nulis
# hasil di akhir doang (buffered), jadi kita gak bisa hitung baris progress-nya. Cuma kasih tau
# "masih hidup, udah sekian lama", tiap <interval_detik> (default 30s).
simple_heartbeat() {
    local label="$1"; local interval="${2:-30}"
    local start; start=$(date +%s)
    while true; do
        sleep "$interval"
        echo -e "[$(ts)] \033[1;33m[HEARTBEAT]\033[0m $label masih jalan... ($(fmt_duration $(( $(date +%s) - start ))) berlalu, belum ada progress terukur krn tool ini nulis hasil di akhir)"
    done
}

# run_takeover_checks <outdir> - dijalankan SEBAGAI BACKGROUND JOB begitu resolved_subs.txt siap.
# Jalan paralel sama Stage 4-8, gak nunggu / gak ngeblok tahapan lain.
# Cek terhadap SEMUA subdomain yang resolve (bukan cuma yg 404), krn banyak signature takeover
# justru muncul di status 200 (mis. "There isn't a GitHub Pages site here", NoSuchBucket S3, dst).
run_takeover_checks() {
    local outdir="$1"
    local errlog="$outdir/tool_errors_takeover.log"
    mkdir -p "$outdir/takeover"
    local input="$outdir/resolved_subs.txt"
    if [[ ! -s "$input" ]]; then
        touch "$outdir/takeover_candidates.txt" "$outdir/takeover_done.flag"
        return
    fi

    if [[ -x "$STRATUS_SUBDOMINATOR_BIN" ]]; then
        echo "=== [takeover] Subdominator (Stratus-Security) $(date '+%Y-%m-%d %H:%M:%S') ===" >> "$errlog"
        "$STRATUS_SUBDOMINATOR_BIN" -l "$input" -o "$outdir/takeover/stratus-subdominator_raw.txt" -t 50 --validate 1>/dev/null 2>>"$errlog"
    fi

    if command -v subzy &>/dev/null; then
        echo "=== [takeover] subzy $(date '+%Y-%m-%d %H:%M:%S') ===" >> "$errlog"
        subzy run --targets "$input" --hide_fails --output "$outdir/takeover/subzy_raw.txt" 1>/dev/null 2>>"$errlog"
    fi

    if command -v nuclei &>/dev/null; then
        echo "=== [takeover] nuclei http/takeovers/ $(date '+%Y-%m-%d %H:%M:%S') ===" >> "$errlog"
        nuclei -l "$input" -t http/takeovers/ -silent -o "$outdir/takeover/nuclei_raw.txt" 1>/dev/null 2>>"$errlog"
    fi

    if command -v subjack &>/dev/null; then
        # subjack v3.0.0+ TIDAK PAKAI lagi fingerprints.json eksternal (fingerprint sudah native di binary).
        # Sekalian aktifkan semua deteksi tambahan yang ada: -a (semua URL, direkomendasikan resmi),
        # -ns (NS delegation takeover), -ar (stale A record), -axfr (zone transfer), -mail (SPF/MX takeover)
        echo "=== [takeover] subjack (v3, native fingerprint + full checks) $(date '+%Y-%m-%d %H:%M:%S') ===" >> "$errlog"
        subjack -w "$input" -t 50 -timeout 15 -ssl -a -ns -ar -axfr -mail -v -o "$outdir/takeover/subjack_raw.txt" 1>/dev/null 2>>"$errlog"
    fi

    if command -v tko-subs &>/dev/null; then
        local tko_csv="$outdir/takeover/tko-subs-providers.csv"
        echo "=== [takeover] tko-subs - download providers-data.csv $(date '+%Y-%m-%d %H:%M:%S') ===" >> "$errlog"
        curl -sL -o "$tko_csv" "https://raw.githubusercontent.com/anshumanbh/tko-subs/master/providers-data.csv" 2>>"$errlog"
        if [[ -s "$tko_csv" ]]; then
            echo "=== [takeover] tko-subs run $(date '+%Y-%m-%d %H:%M:%S') ===" >> "$errlog"
            tko-subs -domains="$input" -data="$tko_csv" -output="$outdir/takeover/tkosubs_raw.csv" 1>/dev/null 2>>"$errlog"
            [[ -f "$outdir/takeover/tkosubs_raw.csv" ]] && grep -i "true" "$outdir/takeover/tkosubs_raw.csv" > "$outdir/takeover/tkosubs_vulnerable.txt" 2>>"$errlog"
        else
            echo "tko-subs: gagal download providers-data.csv ($(wc -c < "$tko_csv" 2>/dev/null || echo 0) byte) — di-skip" >> "$errlog"
        fi
    fi

    if [[ -f "$DNSREAPER_DIR/main.py" ]]; then
        echo "=== [takeover] dnsReaper $(date '+%Y-%m-%d %H:%M:%S') ===" >> "$errlog"
        # dnsReaper flag OUTPUT yang benar: --out <path> --out-format json (BUKAN --json)
        python3 "$DNSREAPER_DIR/main.py" file --filename "$input" --out "$outdir/takeover/dnsreaper_raw" --out-format json 1>/dev/null 2>>"$errlog"
        [[ -f "$outdir/takeover/dnsreaper_raw" && ! -f "$outdir/takeover/dnsreaper_raw.json" ]] && mv "$outdir/takeover/dnsreaper_raw" "$outdir/takeover/dnsreaper_raw.json"
    fi

    # Konsolidasi semua sumber jadi satu file, tetap simpan raw per-tool buat verifikasi manual
    cat "$outdir/takeover"/*_raw.txt "$outdir/takeover"/tkosubs_vulnerable.txt 2>/dev/null | grep -v '^\s*$' | sort -u > "$outdir/takeover_candidates.txt"
    touch "$outdir/takeover_done.flag"
}

# run_secret_scan <outdir> - dijalankan SEBAGAI BACKGROUND JOB begitu js_files.txt siap (akhir Stage 6).
# Jalan paralel sama Stage 7-8, gak nunggu / gak ngeblok tahapan lain.
# Cari token/API key/credential yang ke-expose di JS pakai 3 sumber berbeda:
#   SecretFinder (regex khusus JS), trufflehog (verified secret detection), nuclei (template token/apikey)
run_secret_scan() {
    local outdir="$1"
    local errlog="$outdir/tool_errors_secrets.log"
    local js_list="$outdir/js_files.txt"
    mkdir -p "$outdir/secrets" "$outdir/js_dump"
    if [[ ! -s "$js_list" ]]; then
        touch "$outdir/secrets_candidates.txt" "$outdir/secrets_done.flag"
        return
    fi

    echo "=== [secrets] download JS files $(date '+%Y-%m-%d %H:%M:%S') ===" >> "$errlog"
    local i=0
    while IFS= read -r jsurl; do
        i=$((i+1))
        curl -sL -m 15 "$jsurl" -o "$outdir/js_dump/js_${i}.js" 2>>"$errlog"
    done < "$js_list"

    if [[ -f "$SECRETFINDER_DIR/SecretFinder.py" ]]; then
        echo "=== [secrets] SecretFinder $(date '+%Y-%m-%d %H:%M:%S') ===" >> "$errlog"
        : > "$outdir/secrets/secretfinder_raw.txt"
        while IFS= read -r jsurl; do
            python3 "$SECRETFINDER_DIR/SecretFinder.py" -i "$jsurl" -o cli 2>>"$errlog" >> "$outdir/secrets/secretfinder_raw.txt"
        done < "$js_list"
    fi

    if command -v trufflehog &>/dev/null; then
        echo "=== [secrets] trufflehog $(date '+%Y-%m-%d %H:%M:%S') ===" >> "$errlog"
        trufflehog filesystem "$outdir/js_dump" --json --no-update 2>>"$errlog" > "$outdir/secrets/trufflehog_raw.json"
    fi

    if command -v nuclei &>/dev/null; then
        echo "=== [secrets] nuclei exposures/tokens+apikeys $(date '+%Y-%m-%d %H:%M:%S') ===" >> "$errlog"
        nuclei -l "$js_list" -t exposures/tokens/,exposures/apikeys/ -silent -o "$outdir/secrets/nuclei_raw.txt" 2>>"$errlog"
    fi

    # Konsolidasi (trufflehog JSON diringkas jadi 1 baris per temuan biar konsisten sama file txt lain)
    if [[ -s "$outdir/secrets/trufflehog_raw.json" ]]; then
        grep -o '"Raw":"[^"]*"' "$outdir/secrets/trufflehog_raw.json" 2>/dev/null | sed 's/"Raw":"/[trufflehog] /;s/"$//' > "$outdir/secrets/trufflehog_summary.txt"
    fi
    cat "$outdir/secrets"/*.txt 2>/dev/null | grep -v '^\s*$' | sort -u > "$outdir/secrets_candidates.txt"
    touch "$outdir/secrets_done.flag"
}

detect_chrome() {
    local bin=""
    for candidate in google-chrome google-chrome-stable chromium chromium-browser; do
        if command -v "$candidate" &>/dev/null; then bin="$(command -v "$candidate")"; break; fi
    done
    if [[ -z "$bin" ]]; then
        warn "Chrome/Chromium tidak ditemukan, mencoba install chromium..."
        sudo apt-get install -y chromium 2>/dev/null || sudo apt-get install -y chromium-browser 2>/dev/null
        for candidate in chromium chromium-browser; do
            if command -v "$candidate" &>/dev/null; then bin="$(command -v "$candidate")"; break; fi
        done
    fi
    echo "$bin"
}

# ---------- PRECHECK ----------
if ! command -v go &>/dev/null; then
    # Go mungkin sudah terinstall tapi PATH shell ini belum include lokasinya
    # (umum kejadian kalau install manual via tarball, bukan lewat apt/snap)
    for candidate_dir in /usr/local/go/bin "$HOME/go/bin" /usr/lib/go/bin /snap/bin /opt/go/bin; do
        if [[ -x "$candidate_dir/go" ]]; then
            export PATH="$PATH:$candidate_dir"
            log "Go ditemukan di $candidate_dir tapi belum ada di PATH — otomatis ditambahkan buat sesi ini."
            break
        fi
    done
fi

if ! command -v go &>/dev/null; then
    err "Go tidak ditemukan di PATH manapun (termasuk lokasi umum: /usr/local/go/bin, \$HOME/go/bin, /snap/bin)."
    err "Diagnostic — jalankan manual buat cek:"
    err "  which go"
    err "  ls -la /usr/local/go/bin/go 2>/dev/null"
    err "  echo \$PATH"
    err "Kalau Go beneran belum terinstall: sudo apt install golang-go"
    err "Kalau Go SUDAH terinstall tapi tetap gak ketemu, tambahkan PATH-nya secara permanen ke ~/.bashrc, contoh:"
    err "  echo 'export PATH=\$PATH:/usr/local/go/bin' >> ~/.bashrc && source ~/.bashrc"
    exit 1
fi
ok "Go ditemukan: $(command -v go) ($(go version 2>/dev/null))"
mkdir -p "$GOBIN"

if [[ ! -f "$TARGET_FILE" ]]; then
    err "File target '$TARGET_FILE' tidak ditemukan."
    echo "Buat dulu: nano $TARGET_FILE  (isi 1 domain per baris)"
    exit 1
fi

TARGET_COUNT=$(grep -cve '^\s*$' "$TARGET_FILE")
[[ "$TARGET_COUNT" -eq 0 ]] && { err "File target kosong."; exit 1; }

mkdir -p "$OUTDIR"
cp "$TARGET_FILE" "$OUTDIR/targets.txt"

if [[ -n "$LOG_FILE" ]]; then
    exec > >(tee -a "$LOG_FILE") 2>&1
fi

ok "Ditemukan $TARGET_COUNT target di $TARGET_FILE, output -> $OUTDIR/"
if [[ -n "$LOG_FILE" ]]; then
    ok "Logging ke file aktif -> $LOG_FILE (buka pakai 'tail -f $LOG_FILE' atau 'less +F $LOG_FILE' dari terminal lain biar gak kepotong scrollback)"
fi

if [[ -f "$EXCLUDE_FILE" && -s "$EXCLUDE_FILE" ]]; then
    cp "$EXCLUDE_FILE" "$OUTDIR/excludes.txt"
    ok "Exclude-list aktif: $(grep -cve '^\s*$' "$EXCLUDE_FILE") pattern dari $EXCLUDE_FILE"
else
    warn "Tidak ada exclude-list — pastikan targets.txt sudah sesuai scope resmi!"
fi

# ---------- CEK & INSTALL TOOLS ----------
log "Mengecek dependency tools..."
check_or_install "subfinder" "go install -v github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest"
check_or_install "assetfinder" "go install -v github.com/tomnomnom/assetfinder@latest"
if command -v cargo &>/dev/null && ! command -v findomain &>/dev/null; then
    log "findomain belum ada, mencoba install via cargo (bisa agak lama, compile Rust)..."
    cargo install findomain --locked &>/dev/null
fi
command -v findomain &>/dev/null && ok "findomain sudah terinstall" || warn "findomain tidak tersedia, salah satu sumber passive enum akan di-skip"

# github-subdomains & chaos butuh API key/token - opsional, di-skip otomatis kalau env var gak di-set
if [[ -n "${GITHUB_TOKEN:-}" ]]; then
    check_or_install "github-subdomains" "go install -v github.com/gwen001/github-subdomains@latest"
else
    warn "GITHUB_TOKEN gak di-set — github-subdomains di-skip (opsional, set env GITHUB_TOKEN buat aktifin)"
fi
if [[ -n "${CHAOS_API_KEY:-}" ]]; then
    check_or_install "chaos" "go install -v github.com/projectdiscovery/chaos-client/cmd/chaos@latest"
else
    warn "CHAOS_API_KEY gak di-set — chaos di-skip (opsional, daftar gratis di chaos.projectdiscovery.io buat aktifin)"
fi
check_or_install "amass"     "go install -v github.com/owasp-amass/amass/v4/...@master"
check_or_install "dnsx"      "go install -v github.com/projectdiscovery/dnsx/cmd/dnsx@latest"
check_or_install "alterx"    "go install -v github.com/projectdiscovery/alterx/cmd/alterx@latest"
check_or_install "gotator"   "go install -v github.com/Josue87/gotator@latest"
if command -v pip3 &>/dev/null && ! command -v dnsgen &>/dev/null; then
    log "dnsgen belum ada, mencoba install..."
    pip3 install --break-system-packages dnsgen &>/dev/null
fi
command -v dnsgen &>/dev/null && ok "dnsgen tersedia" || warn "dnsgen tidak tersedia, salah satu sumber permutation akan di-skip"
if command -v cargo &>/dev/null && ! command -v ripgen &>/dev/null; then
    log "ripgen belum ada, mencoba install via cargo..."
    cargo install ripgen &>/dev/null
fi
command -v ripgen &>/dev/null && ok "ripgen tersedia" || warn "ripgen tidak tersedia, salah satu sumber permutation akan di-skip"
check_or_install "httpx"     "go install -v github.com/projectdiscovery/httpx/cmd/httpx@latest"
check_or_install "katana"    "go install -v github.com/projectdiscovery/katana/cmd/katana@latest"
check_or_install "gau"       "go install -v github.com/lc/gau/v2/cmd/gau@latest"
check_or_install "waybackurls" "go install -v github.com/tomnomnom/waybackurls@latest"
check_or_install "gauplus"    "go install -v github.com/bp0lr/gauplus@latest"
check_or_install "subjs"     "go install -v github.com/lc/subjs@latest"
