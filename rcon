fi
[[ -f "$THEHARVESTER_DIR/theHarvester.py" ]] && ok "theHarvester tersedia" || warn "theHarvester tidak tersedia, salah satu sumber passive enum akan di-skip"

DNSREAPER_DIR="${GOBIN}/../dnsReaper"
if [[ ! -d "$DNSREAPER_DIR" ]]; then
    log "dnsReaper belum ada, mencoba install (clone + pip requirements)..."
    git clone --depth 1 https://github.com/punk-security/dnsReaper.git "$DNSREAPER_DIR" &>/dev/null
    if [[ -f "$DNSREAPER_DIR/requirements.txt" ]]; then
        pip3 install --break-system-packages -r "$DNSREAPER_DIR/requirements.txt" &>/dev/null
    fi
fi
[[ -f "$DNSREAPER_DIR/main.py" ]] && ok "dnsReaper tersedia" || warn "dnsReaper tidak tersedia, salah satu sumber takeover-check akan di-skip"

# Tools JS secret scanning — cari token/API key/credential yang ke-expose di JS
check_or_install "trufflehog" "go install github.com/trufflesecurity/trufflehog/v3@latest"
SECRETFINDER_DIR="${GOBIN}/../SecretFinder"
if [[ ! -f "$SECRETFINDER_DIR/SecretFinder.py" ]]; then
