fi

# Tools subdomain takeover — 5 sumber fingerprint berbeda biar coverage maksimal
check_or_install "subzy"     "go install -v github.com/PentestPad/subzy@latest"
check_or_install "subjack"   "go install -v github.com/haccer/subjack@latest"
check_or_install "tko-subs"  "go install -v github.com/anshumanbh/tko-subs@latest"

# Subdominator (Stratus-Security, C#) - takeover checker asli, benchmark 100k subdomain 19 menit
# (vs subjack 2.5 jam). Bukan Python/pip package "SubDominator" (beda tool, itu buat enum).
# Distribusi cuma binary compiled, gak ada di package manager - download langsung dari GitHub Releases.
STRATUS_SUBDOMINATOR_BIN="${GOBIN}/../stratus-subdominator/Subdominator"
if [[ ! -x "$STRATUS_SUBDOMINATOR_BIN" ]]; then
    log "Subdominator (Stratus-Security, takeover checker) belum ada, mencoba download binary..."
    mkdir -p "$(dirname "$STRATUS_SUBDOMINATOR_BIN")"
    curl -sL -o "$STRATUS_SUBDOMINATOR_BIN" "https://github.com/Stratus-Security/Subdominator/releases/latest/download/Subdominator" 2>/tmp/stratus_dl.log
    chmod +x "$STRATUS_SUBDOMINATOR_BIN" 2>/dev/null
fi
[[ -x "$STRATUS_SUBDOMINATOR_BIN" ]] && ok "Subdominator (Stratus-Security, takeover) tersedia" || warn "Subdominator (Stratus-Security) gagal didownload, salah satu sumber takeover-check akan di-skip"

# Sublist3r - classic passive subdomain enum tool, sumber beda (search engine scraping: google/bing/yahoo/baidu/ask + netcraft/virustotal/threatcrowd/dnsdumpster)
