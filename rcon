        pip3 install --break-system-packages -r "$SUBLIST3R_DIR/requirements.txt" &>/dev/null
    fi
fi
[[ -f "$SUBLIST3R_DIR/sublist3r.py" ]] && ok "Sublist3r tersedia" || warn "Sublist3r tidak tersedia, salah satu sumber passive enum akan di-skip"

# theHarvester - multi-source OSINT klasik (puluhan search engine/API), kita ambil subdomain-nya doang
THEHARVESTER_DIR="${GOBIN}/../theHarvester"
if [[ ! -f "$THEHARVESTER_DIR/theHarvester.py" ]]; then
