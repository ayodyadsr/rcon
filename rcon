[[ -f "$SECRETFINDER_DIR/SecretFinder.py" ]] && ok "SecretFinder tersedia" || warn "SecretFinder tidak tersedia, salah satu sumber secret-scan akan di-skip"

if command -v pip3 &>/dev/null && ! command -v arjun &>/dev/null; then
    log "arjun belum ada, mencoba install..."
    pip3 install --break-system-packages arjun &>/dev/null
fi
command -v arjun &>/dev/null && ok "arjun tersedia" || warn "arjun tidak tersedia, parameter discovery akan di-skip"

if ! command -v gowitness &>/dev/null; then
    log "gowitness belum ada, mencoba install..."
    go install -v github.com/sensepost/gowitness@latest
fi
command -v gowitness &>/dev/null && ok "gowitness tersedia" || warn "gowitness gagal diinstall (butuh chromium)"

# Deteksi Chrome/Chromium SEKALI di awal, dipakai bareng oleh katana -hl dan gowitness
log "Mendeteksi browser Chrome/Chromium..."
CHROME_BIN="$(detect_chrome)"
[[ -n "$CHROME_BIN" ]] && ok "Browser terdeteksi: $CHROME_BIN" || warn "Browser tidak ditemukan, headless crawl & screenshot akan di-skip"

RESOLVERS_FILE="$OUTDIR/resolvers.txt"
log "Mengambil resolver list terkini..."
if curl -s -o "$RESOLVERS_FILE" "$RESOLVERS_URL" && [[ -s "$RESOLVERS_FILE" ]]; then
    ok "Resolver list disimpan ($(cat "$RESOLVERS_FILE" 2>/dev/null | wc -l) resolver)"
else
    warn "Gagal ambil resolver list, dnsx pakai resolver default sistem"
    rm -f "$RESOLVERS_FILE"
fi

# ---------- STAGE 1: PASSIVE ENUM MULTI-SUMBER + ACTIVE ZONE TRANSFER CHECK (skip kalau targeted) ----------
if [[ "$SCAN_MODE" == "wildcard" ]]; then
    stage "Passive enum 9-sumber + AXFR check (active) [mode: wildcard]"
    : > "$OUTDIR/raw_subs_pre_exclude.txt"
    : > "$OUTDIR/axfr_results.txt"
    while IFS= read -r domain; do
        [[ -z "$domain" || "$domain" =~ ^# ]] && continue
        log "  -> $domain"

        t0=$(date +%s)
        log "     [PASSIVE 1/9] subfinder..."
        subfinder -d "$domain" -all -silent >> "$OUTDIR/raw_subs_pre_exclude.txt" 2>>"$OUTDIR/tool_errors.log"
        log "     [PASSIVE 1/9] subfinder selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"

        if command -v amass &>/dev/null; then
            t0=$(date +%s)
            log "     [PASSIVE 2/9] amass..."
            simple_heartbeat "amass ($domain)" 30 &
            HB_PID=$!
            amass enum -passive -d "$domain" -silent >> "$OUTDIR/raw_subs_pre_exclude.txt" 2>>"$OUTDIR/tool_errors.log"
            kill "$HB_PID" 2>/dev/null; wait "$HB_PID" 2>/dev/null
            log "     [PASSIVE 2/9] amass selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
        else
            log "     [PASSIVE 2/9] amass di-skip (gak terinstall)"
        fi

        if command -v assetfinder &>/dev/null; then
            t0=$(date +%s)
            log "     [PASSIVE 3/9] assetfinder..."
            assetfinder --subs-only "$domain" >> "$OUTDIR/raw_subs_pre_exclude.txt" 2>>"$OUTDIR/tool_errors.log"
            log "     [PASSIVE 3/9] assetfinder selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
        else
            log "     [PASSIVE 3/9] assetfinder di-skip (gak terinstall)"
        fi

        if command -v findomain &>/dev/null; then
            t0=$(date +%s)
            log "     [PASSIVE 4/9] findomain..."
            findomain -t "$domain" -q >> "$OUTDIR/raw_subs_pre_exclude.txt" 2>>"$OUTDIR/tool_errors.log"
            log "     [PASSIVE 4/9] findomain selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
        else
            log "     [PASSIVE 4/9] findomain di-skip (gak terinstall)"
        fi

        t0=$(date +%s)
        log "     [PASSIVE 5/9] crt.sh (certificate transparency)..."
        curl -s "https://crt.sh/?q=%25.${domain}&output=json" \
            | grep -oE '"name_value":"[^"]+"' | sed -E 's/"name_value":"//;s/"//' \
            | sed 's/\*\.//g' | tr ',' '\n' >> "$OUTDIR/raw_subs_pre_exclude.txt" 2>/dev/null
        log "     [PASSIVE 5/9] crt.sh selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"

        t0=$(date +%s)
        log "     [PASSIVE 6/9] Certspotter (certificate transparency, sumber beda dari crt.sh)..."
        curl -s "https://api.certspotter.com/v1/issuances?domain=${domain}&include_subdomains=true&expand=dns_names" \
            | grep -oE '"dns_names":\[[^]]+\]' | grep -oE '"[a-zA-Z0-9_.*-]+\.'"${domain//./\\.}"'"' \
            | tr -d '"' | sed 's/^\*\.//' >> "$OUTDIR/raw_subs_pre_exclude.txt" 2>>"$OUTDIR/tool_errors.log"
        log "     [PASSIVE 6/9] Certspotter selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"

        if [[ -f "$SUBLIST3R_DIR/sublist3r.py" ]]; then
            t0=$(date +%s)
            log "     [PASSIVE 7/9] Sublist3r (search engine scraping)..."
            python3 "$SUBLIST3R_DIR/sublist3r.py" -d "$domain" -o "$OUTDIR/.sublist3r_tmp.txt" 2>>"$OUTDIR/tool_errors.log" 1>/dev/null
            [[ -f "$OUTDIR/.sublist3r_tmp.txt" ]] && cat "$OUTDIR/.sublist3r_tmp.txt" >> "$OUTDIR/raw_subs_pre_exclude.txt" && rm -f "$OUTDIR/.sublist3r_tmp.txt"
            log "     [PASSIVE 7/9] Sublist3r selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
        else
            log "     [PASSIVE 7/9] Sublist3r di-skip (gak terinstall)"
        fi

        if [[ -f "$THEHARVESTER_DIR/theHarvester.py" ]]; then
            t0=$(date +%s)
            log "     [PASSIVE 8/9] theHarvester (multi-source OSINT)..."
            (cd "$THEHARVESTER_DIR" && python3 theHarvester.py -d "$domain" -b all -f "$OUTDIR/.theharvester_tmp" 2>>"$OUTDIR/tool_errors.log" 1>/dev/null)
            if [[ -f "$OUTDIR/.theharvester_tmp.json" ]]; then
                grep -oE '"[a-zA-Z0-9_.-]+\.'"${domain//./\\.}"'"' "$OUTDIR/.theharvester_tmp.json" | tr -d '"' >> "$OUTDIR/raw_subs_pre_exclude.txt"
                rm -f "$OUTDIR/.theharvester_tmp.json"
            fi
            log "     [PASSIVE 8/9] theHarvester selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
        else
            log "     [PASSIVE 8/9] theHarvester di-skip (gak terinstall)"
        fi

        if command -v github-subdomains &>/dev/null && [[ -n "${GITHUB_TOKEN:-}" ]]; then
            t0=$(date +%s)
            log "     [PASSIVE 9/9] github-subdomains (code search)..."
            github-subdomains -d "$domain" -t "$GITHUB_TOKEN" >> "$OUTDIR/raw_subs_pre_exclude.txt" 2>>"$OUTDIR/tool_errors.log"
            log "     [PASSIVE 9/9] github-subdomains selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
        else
            log "     [PASSIVE 9/9] github-subdomains di-skip (gak terinstall / GITHUB_TOKEN gak di-set)"
        fi

        if command -v chaos &>/dev/null && [[ -n "${CHAOS_API_KEY:-}" ]]; then
            t0=$(date +%s)
            log "     [PASSIVE bonus] chaos (ProjectDiscovery dataset)..."
            chaos -d "$domain" -key "$CHAOS_API_KEY" -silent >> "$OUTDIR/raw_subs_pre_exclude.txt" 2>>"$OUTDIR/tool_errors.log"
            log "     [PASSIVE bonus] chaos selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
        fi

        # ACTIVE: zone transfer (AXFR) check - coba tiap nameserver domain, laporan kalau ada yg misconfigured
        if command -v dig &>/dev/null; then
            t0=$(date +%s)
            log "     [ACTIVE] Zone transfer (AXFR) check ke semua nameserver..."
            ns_list=$(dig +short NS "$domain" 2>>"$OUTDIR/tool_errors.log")
            if [[ -n "$ns_list" ]]; then
                while IFS= read -r ns; do
                    [[ -z "$ns" ]] && continue
                    axfr_result=$(dig axfr "$domain" "@$ns" 2>>"$OUTDIR/tool_errors.log")
                    # AXFR sukses kalau ada lebih dari 1 baris SOA record (transfer normal cuma nolak/timeout kalau di-disable)
                    if [[ -n "$axfr_result" ]] && [[ "$(echo "$axfr_result" | grep -c 'SOA')" -gt 1 ]]; then
                        echo "!!! AXFR TERBUKA di $ns untuk $domain !!!" >> "$OUTDIR/axfr_results.txt"
                        echo "$axfr_result" >> "$OUTDIR/axfr_results.txt"
                        err "  !!! ZONE TRANSFER TERBUKA di $ns untuk $domain — cek $OUTDIR/axfr_results.txt !!!"
                    fi
                done <<< "$ns_list"
            fi
            log "     [ACTIVE] AXFR check selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
        else
            log "     [ACTIVE] AXFR check di-skip (dig gak terinstall — sudo apt install dnsutils)"
        fi
    done < "$TARGET_FILE"
    sort -u "$OUTDIR/raw_subs_pre_exclude.txt" -o "$OUTDIR/raw_subs_pre_exclude.txt"
else
    stage "Skip passive enum [mode: targeted] — pakai targets.txt apa adanya sebagai host list"
    sort -u "$TARGET_FILE" -o "$OUTDIR/raw_subs_pre_exclude.txt" 2>/dev/null || cp "$TARGET_FILE" "$OUTDIR/raw_subs_pre_exclude.txt"
fi

apply_exclude "$OUTDIR/raw_subs_pre_exclude.txt" "$OUTDIR/raw_subs.txt"
EXCLUDED_COUNT=$(( $(cat "$OUTDIR/raw_subs_pre_exclude.txt" 2>/dev/null | wc -l) - $(cat "$OUTDIR/raw_subs.txt" 2>/dev/null | wc -l) ))
ok "Host awal: $(cat "$OUTDIR/raw_subs.txt" 2>/dev/null | wc -l) unik, $EXCLUDED_COUNT di-exclude sesuai scope"

# ---------- STAGE 2: ACTIVE GENERATION - PERMUTATION (multi-tools) + WORDLIST BRUTEFORCE (skip kalau targeted) ----------
if [[ "$SCAN_MODE" == "wildcard" ]]; then
    stage "Active generation: permutation (alterx+gotator+dnsgen+ripgen) + wordlist bruteforce [mode: wildcard]"

    # Wordlist dipakai bareng oleh gotator/dnsgen/ripgen (butuh wordlist eksplisit) DAN straightforward bruteforce di bawah
    WORDLIST_CACHE="$HOME/.cache/recon_subdomain_wordlist.txt"
    mkdir -p "$(dirname "$WORDLIST_CACHE")"
    if [[ ! -s "$WORDLIST_CACHE" ]]; then
        log "  Download wordlist SecLists (sekali aja, di-cache buat run selanjutnya)..."
        curl -sL -o "$WORDLIST_CACHE" "https://raw.githubusercontent.com/danielmiessler/SecLists/master/Discovery/DNS/subdomains-top1million-5000.txt" 2>>"$OUTDIR/tool_errors.log"
    fi

    : > "$OUTDIR/permutations_raw.txt"

    if command -v alterx &>/dev/null; then
        t0=$(date +%s)
        log "  [PERM 1/4] alterx..."
        alterx -l "$OUTDIR/raw_subs.txt" -silent -o "$OUTDIR/alterx_raw.txt" 2>>"$OUTDIR/tool_errors.log"
        cat "$OUTDIR/alterx_raw.txt" >> "$OUTDIR/permutations_raw.txt" 2>/dev/null
        log "  [PERM 1/4] alterx selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
    else
        log "  [PERM 1/4] alterx di-skip (gak terinstall)"
    fi

    if command -v gotator &>/dev/null && [[ -s "$WORDLIST_CACHE" ]]; then
        t0=$(date +%s)
        log "  [PERM 2/4] gotator..."
        gotator -sub "$OUTDIR/raw_subs.txt" -perm "$WORDLIST_CACHE" -depth 1 -numbers 3 -mindup -adv -silent >> "$OUTDIR/permutations_raw.txt" 2>>"$OUTDIR/tool_errors.log"
        log "  [PERM 2/4] gotator selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
    else
        log "  [PERM 2/4] gotator di-skip (gak terinstall / wordlist gak ada)"
    fi

    if command -v dnsgen &>/dev/null; then
        t0=$(date +%s)
        log "  [PERM 3/4] dnsgen..."
        cat "$OUTDIR/raw_subs.txt" | dnsgen - 2>>"$OUTDIR/tool_errors.log" >> "$OUTDIR/permutations_raw.txt"
        log "  [PERM 3/4] dnsgen selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
    else
        log "  [PERM 3/4] dnsgen di-skip (gak terinstall)"
    fi

    if command -v ripgen &>/dev/null && [[ -s "$WORDLIST_CACHE" ]]; then
        t0=$(date +%s)
        log "  [PERM 4/4] ripgen..."
        ripgen -d "$OUTDIR/raw_subs.txt" -w "$WORDLIST_CACHE" 2>>"$OUTDIR/tool_errors.log" >> "$OUTDIR/permutations_raw.txt"
        log "  [PERM 4/4] ripgen selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
    else
        log "  [PERM 4/4] ripgen di-skip (gak terinstall / wordlist gak ada)"
    fi

    sort -u "$OUTDIR/permutations_raw.txt" -o "$OUTDIR/permutations_raw.txt"
    apply_exclude "$OUTDIR/permutations_raw.txt" "$OUTDIR/permutations.txt"
    cat "$OUTDIR/permutations.txt" >> "$OUTDIR/raw_subs.txt" 2>/dev/null
    sort -u "$OUTDIR/raw_subs.txt" -o "$OUTDIR/raw_subs.txt"
    ok "Permutation (gabungan 4 tools, dedup): total sekarang $(cat "$OUTDIR/raw_subs.txt" 2>/dev/null | wc -l) kandidat"

    # ACTIVE: straightforward wordlist bruteforce (word.domain langsung, bukan mutasi kata yang udah ketemu) -
    # biar nemu subdomain yang GAK muncul di sumber passive/permutation manapun
    log "  [ACTIVE] Straightforward wordlist bruteforce (SecLists common subdomains)..."
    if [[ -s "$WORDLIST_CACHE" ]]; then
        : > "$OUTDIR/wordlist_bruteforce_raw.txt"
        while IFS= read -r domain; do
            [[ -z "$domain" || "$domain" =~ ^# ]] && continue
            awk -v d="$domain" '{print $0"."d}' "$WORDLIST_CACHE" >> "$OUTDIR/wordlist_bruteforce_raw.txt"
        done < "$TARGET_FILE"
        apply_exclude "$OUTDIR/wordlist_bruteforce_raw.txt" "$OUTDIR/wordlist_bruteforce.txt"
        cat "$OUTDIR/wordlist_bruteforce.txt" >> "$OUTDIR/raw_subs.txt"
        sort -u "$OUTDIR/raw_subs.txt" -o "$OUTDIR/raw_subs.txt"
        ok "  [ACTIVE] Wordlist bruteforce ($(cat "$WORDLIST_CACHE" | wc -l) kata x $TARGET_COUNT domain): total sekarang $(cat "$OUTDIR/raw_subs.txt" 2>/dev/null | wc -l) kandidat"
    else
        warn "  [ACTIVE] Gagal download wordlist, skip bruteforce"
    fi
else
    stage "Skip permutation [mode: targeted] — host sudah presisi, gak perlu digenerate lagi"
fi

# ---------- STAGE 3: MASS RESOLVE ----------
stage "Mass-resolve dengan dnsx"
CANDIDATE_COUNT=$(cat "$OUTDIR/raw_subs.txt" 2>/dev/null | wc -l)
if [[ "$CANDIDATE_COUNT" -gt 50000 ]]; then
    warn "Kandidat subdomain SANGAT BANYAK ($CANDIDATE_COUNT) — kemungkinan besar dari permutation."
    warn "Proses TETAP akan dijalankan sampai tuntas (tanpa cutoff), tapi ini bisa makan waktu cukup lama."
fi
if command -v dnsx &>/dev/null; then
    log "Menjalankan dnsx TANPA batas waktu keseluruhan (bakal jalan sampai semua kandidat selesai dicoba)."
    log "Per-query timeout tetap dipasang (5s) supaya resolver yang mati/gak respon gak bikin satu query nyangkut lama — bukan buat motong proses secara keseluruhan."
    touch "$OUTDIR/resolved_subs_raw.txt"
    heartbeat_monitor "$OUTDIR/resolved_subs_raw.txt" "$CANDIDATE_COUNT" "dnsx resolve" &
    HEARTBEAT_PID=$!
    if [[ -f "$RESOLVERS_FILE" ]]; then
        dnsx -l "$OUTDIR/raw_subs.txt" -silent -r "$RESOLVERS_FILE" -t "$DNSX_THREADS" -retry 1 -timeout 5 -o "$OUTDIR/resolved_subs_raw.txt" 2>>"$OUTDIR/tool_errors.log"
    else
        dnsx -l "$OUTDIR/raw_subs.txt" -silent -t "$DNSX_THREADS" -retry 1 -timeout 5 -o "$OUTDIR/resolved_subs_raw.txt" 2>>"$OUTDIR/tool_errors.log"
    fi
    kill "$HEARTBEAT_PID" 2>/dev/null; wait "$HEARTBEAT_PID" 2>/dev/null
    touch "$OUTDIR/resolved_subs_raw.txt"
    apply_exclude "$OUTDIR/resolved_subs_raw.txt" "$OUTDIR/resolved_subs.txt"
    RESOLVED_COUNT=$(cat "$OUTDIR/resolved_subs.txt" 2>/dev/null | wc -l)
    ok "Resolved: $RESOLVED_COUNT subdomain valid & in-scope (SEMUA kandidat sudah dicoba, tuntas)"
    if [[ "$RESOLVED_COUNT" -eq 0 && "$CANDIDATE_COUNT" -gt 0 ]]; then
        err "0 dari $CANDIDATE_COUNT kandidat berhasil resolve — ini ANEH, kemungkinan ada masalah (resolver rusak/format salah, dnsx error, dll)."
        err "Cek isi $OUTDIR/tool_errors.log buat lihat pesan error asli dari dnsx sebelum lanjut percaya hasil recon ini."
    fi
else
    warn "dnsx tidak tersedia, pakai raw_subs.txt langsung"
    apply_exclude "$OUTDIR/raw_subs.txt" "$OUTDIR/resolved_subs.txt"
fi

# Launch subdomain takeover check di BACKGROUND begitu resolved_subs.txt siap.
# Jalan paralel sama Stage 4-8 (httpx/gau/katana/arjun/gowitness), hasilnya di-join sebelum report.
log "Melepas subdomain takeover check (Subdominator+subzy+nuclei+subjack+tko-subs+dnsReaper) ke background — jalan paralel, gak nunggu."
run_takeover_checks "$OUTDIR" &
TAKEOVER_PID=$!
ok "Takeover check jalan di background (PID: $TAKEOVER_PID)"

# ---------- STAGE 4: LIVE HOST CHECK (MULTI-PORT) ----------
stage "Live host check + tech fingerprint (httpx, multi-port)"
EXTRA_PORTS="${EXTRA_PORTS:-80,81,443,591,593,832,981,1080,1311,2082,2083,2086,2087,2095,2096,2480,3000,3001,3128,3333,4243,4567,4711,4712,5000,5104,5601,5985,5986,6080,6443,6543,7000,7001,7002,7070,7080,7081,7100,7443,7777,8000,8001,8008,8009,8010,8020,8028,8030,8042,8069,8070,8071,8080,8081,8082,8083,8088,8090,8091,8092,8100,8118,8123,8180,8181,8222,8243,8280,8281,8333,8443,8500,8600,8643,8686,8800,8834,8880,8881,8883,8888,9000,9001,9002,9043,9080,9081,9090,9091,9092,9100,9200,9300,9440,9443,9999,10000,10443,15672,18080,27017,50070,50075}"
httpx -l "$OUTDIR/resolved_subs.txt" -ports "$EXTRA_PORTS" -status-code -title -tech-detect -silent \
    -rate-limit "$HTTPX_RATE" -threads "$HTTPX_THREADS" -o "$OUTDIR/live_hosts.txt"
ok "Live hosts: $(cat "$OUTDIR/live_hosts.txt" 2>/dev/null | wc -l) host [semua port, rate: $HTTPX_RATE/s]"

awk '{print $1}' "$OUTDIR/live_hosts.txt" | sed -E 's#https?://##' > "$OUTDIR/live_hosts_only.txt"
awk '{print $1}' "$OUTDIR/live_hosts.txt" > "$OUTDIR/clean_urls_for_screenshot.txt"

# Subset "hidup beneran" (bukan 404) buat headless fallback - hindari waste resource di error page generik
grep -Ev '\[404( |\])' "$OUTDIR/live_hosts.txt" | awk '{print $1}' > "$OUTDIR/interesting_hosts_all.txt"
head -n "$KATANA_HEADLESS_LIMIT" "$OUTDIR/interesting_hosts_all.txt" > "$OUTDIR/interesting_hosts_for_headless.txt"
ok "Host non-404 (kandidat headless crawl): $(cat "$OUTDIR/interesting_hosts_all.txt" 2>/dev/null | wc -l), dibatasi ke $(cat "$OUTDIR/interesting_hosts_for_headless.txt" 2>/dev/null | wc -l) teratas utk headless"

# ---------- STAGE 5: HISTORICAL URL MINING + FILTERING (gau + waybackurls + gauplus) ----------
stage "Historical URL mining (gau + waybackurls + gauplus)"
: > "$OUTDIR/historical_urls_raw.txt"
while IFS= read -r domain; do
    [[ -z "$domain" || "$domain" =~ ^# ]] && continue

    if command -v gau &>/dev/null; then
        t0=$(date +%s)
        log "  [1/3] gau ($domain) - provider: wayback,commoncrawl,otx,urlscan..."
        gau --subs --providers wayback,commoncrawl,otx,urlscan "$domain" 2>>"$OUTDIR/tool_errors.log" >> "$OUTDIR/historical_urls_raw.txt"
        log "  [1/3] gau selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
    fi

    if command -v waybackurls &>/dev/null; then
        t0=$(date +%s)
        log "  [2/3] waybackurls ($domain)..."
        echo "$domain" | waybackurls 2>>"$OUTDIR/tool_errors.log" >> "$OUTDIR/historical_urls_raw.txt"
        log "  [2/3] waybackurls selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
    fi

    if command -v gauplus &>/dev/null; then
        t0=$(date +%s)
        log "  [3/3] gauplus ($domain)..."
        gauplus -subs "$domain" 2>>"$OUTDIR/tool_errors.log" >> "$OUTDIR/historical_urls_raw.txt"
        log "  [3/3] gauplus selesai ($(fmt_duration $(( $(date +%s) - t0 ))))"
    fi
done < "$TARGET_FILE"

if [[ -s "$OUTDIR/historical_urls_raw.txt" ]]; then
    sort -u "$OUTDIR/historical_urls_raw.txt" -o "$OUTDIR/historical_urls_raw.txt"
    apply_exclude "$OUTDIR/historical_urls_raw.txt" "$OUTDIR/historical_urls.txt"
    ok "Historical URLs (gabungan gau+waybackurls+gauplus, dedup): $(cat "$OUTDIR/historical_urls.txt" 2>/dev/null | wc -l) URL (setelah exclude)"

    grep -E '\?[a-zA-Z0-9_]+=' "$OUTDIR/historical_urls.txt" | sort -u > "$OUTDIR/urls_with_params.txt"
    grep -Ei '/(api|graphql|v[0-9]+|internal|admin|backend)(/|\?|$)' "$OUTDIR/historical_urls.txt" | sort -u > "$OUTDIR/urls_api_like.txt"
    grep -Ei '\.(json|xml|env|config|conf|yml|yaml|sql|bak|zip|tar|gz|log|git)(\?|$)' "$OUTDIR/historical_urls.txt" | sort -u > "$OUTDIR/urls_sensitive_ext.txt"
    grep -oE '[?&][a-zA-Z0-9_]+=' "$OUTDIR/historical_urls.txt" | sed -E 's/^[?&]//;s/=$//' | sort -u > "$OUTDIR/param_names.txt"

    ok "  -> urls_with_params.txt   : $(cat "$OUTDIR/urls_with_params.txt" 2>/dev/null | wc -l)"
    ok "  -> urls_api_like.txt      : $(cat "$OUTDIR/urls_api_like.txt" 2>/dev/null | wc -l)"
    ok "  -> urls_sensitive_ext.txt : $(cat "$OUTDIR/urls_sensitive_ext.txt" 2>/dev/null | wc -l)"
    ok "  -> param_names.txt        : $(cat "$OUTDIR/param_names.txt" 2>/dev/null | wc -l)"
else
    warn "gau/waybackurls/gauplus tidak ada satupun yang tersedia atau tidak ada hasil, skip historical URL mining"
fi


# ---------- STAGE 6: CRAWL + JS ENDPOINT MINING (STATIC utk semua host, HEADLESS fallback utk subset) ----------
stage "Crawl + JS endpoint mining (katana static -jc -kf all)"
if command -v katana &>/dev/null; then
    log "Static crawl TANPA batas waktu keseluruhan (bakal jalan sampai crawl tuntas)."
    log "Per-request timeout tetap 10s supaya 1 halaman yg gak pernah 'selesai load' (chat widget/polling script) gak bikin SELURUH proses nyangkut — bukan buat motong hasil crawl."
    katana -list "$OUTDIR/live_hosts_only.txt" -jc -kf all -timeout 10 \
        -silent -rate-limit "$HTTPX_RATE" \
        -o "$OUTDIR/katana_static_raw.txt" 2>>"$OUTDIR/tool_errors.log"
    touch "$OUTDIR/katana_static_raw.txt"
    apply_exclude "$OUTDIR/katana_static_raw.txt" "$OUTDIR/katana_static.txt"
    ok "Static crawl: $(cat "$OUTDIR/katana_static.txt" 2>/dev/null | wc -l) URL ditemukan (semua host, semua port)"

    if [[ -n "$CHROME_BIN" && -s "$OUTDIR/interesting_hosts_for_headless.txt" ]]; then
        log "  [Stage 6 - sub] Headless fallback (katana -hl) untuk $(cat "$OUTDIR/interesting_hosts_for_headless.txt" 2>/dev/null | wc -l) host non-404, TANPA batas waktu keseluruhan (per-request timeout 15s tetap aktif)..."
        katana -list "$OUTDIR/interesting_hosts_for_headless.txt" -jc -kf all -hl -system-chrome \
            -timeout 15 -silent \
            -rate-limit "$HTTPX_RATE" -o "$OUTDIR/katana_headless_raw.txt" 2>>"$OUTDIR/tool_errors.log"
        touch "$OUTDIR/katana_headless_raw.txt"
        apply_exclude "$OUTDIR/katana_headless_raw.txt" "$OUTDIR/katana_headless.txt"
        ok "Headless crawl: $(cat "$OUTDIR/katana_headless.txt" 2>/dev/null | wc -l) URL tambahan (SPA/JS-rendered content)"
    else
        warn "Skip headless fallback (browser tidak ada / tidak ada host non-404)"
        : > "$OUTDIR/katana_headless.txt"
    fi

    cat "$OUTDIR/katana_static.txt" "$OUTDIR/katana_headless.txt" 2>/dev/null | sort -u > "$OUTDIR/katana_urls.txt"
    ok "Katana total (static+headless, dedup): $(cat "$OUTDIR/katana_urls.txt" 2>/dev/null | wc -l)"

    grep -E '\.js(\?|$)' "$OUTDIR/katana_urls.txt" 2>/dev/null | sort -u > "$OUTDIR/js_files.txt"
    ok "JS files ditemukan: $(cat "$OUTDIR/js_files.txt" 2>/dev/null | wc -l)"

    # Launch JS secret scan di BACKGROUND begitu js_files.txt siap.
    # Fungsi ini JUGA download semua JS ke js_dump/ - dipakai bareng buat ekstraksi endpoint di Stage 8,
    # biar gak download 2x (dulu ada loop curl terpisah di sini yang boros + gak ada timeout per-request).
    log "Melepas JS secret scan (SecretFinder+trufflehog+nuclei) ke background — jalan paralel, gak nunggu."
    run_secret_scan "$OUTDIR" &
    SECRETS_PID=$!
    ok "Secret scan jalan di background (PID: $SECRETS_PID)"

    cat "$OUTDIR/katana_urls.txt" "$OUTDIR"/historical_urls.txt 2>/dev/null | sort -u > "$OUTDIR/all_urls_combined_raw.txt"
    awk -F'?' '{
        if ($2) { n=split($2,a,"&"); line=$1"?"; for(i=1;i<=n;i++){ split(a[i],kv,"="); line=line kv[1] (i<n?"&":"") }; print line }
        else print $1
    }' "$OUTDIR/all_urls_combined_raw.txt" | sort -u > "$OUTDIR/all_urls_normalized.txt"
    ok "URL gabungan setelah normalize+dedup: $(cat "$OUTDIR/all_urls_normalized.txt" 2>/dev/null | wc -l) (dari $(cat "$OUTDIR/all_urls_combined_raw.txt" 2>/dev/null | wc -l) mentah)"
else
    warn "katana tidak tersedia, skip JS/endpoint mining"
fi

# ---------- STAGE 7: PARAMETER DISCOVERY ----------
stage "Parameter discovery (arjun)"
if command -v arjun &>/dev/null && [[ -s "$OUTDIR/live_hosts_only.txt" ]]; then
    head -n 15 "$OUTDIR/live_hosts_only.txt" > "$OUTDIR/arjun_targets.txt"
    arjun -i "$OUTDIR/arjun_targets.txt" -oT "$OUTDIR/arjun_results.txt" -t 5 --rate-limit "$HTTPX_RATE" &>/dev/null
    if [[ -s "$OUTDIR/arjun_results.txt" ]]; then
        ok "Parameter discovery selesai -> $OUTDIR/arjun_results.txt (15 host teratas)"
    else
        warn "Arjun tidak menemukan parameter baru"
    fi
else
    warn "arjun tidak tersedia atau tidak ada live host, skip"
fi

# ---------- STAGE 8: JOIN HASIL PROSES PARALEL (takeover check + secret scan) ----------
stage "Join hasil takeover check + JS secret scan (proses paralel)"
if [[ -n "${TAKEOVER_PID:-}" ]]; then
    log "Menunggu proses takeover check (Subdominator+subzy+nuclei+subjack+tko-subs+dnsReaper) selesai kalau masih jalan..."
    wait "$TAKEOVER_PID" 2>/dev/null
    TAKEOVER_COUNT=$(cat "$OUTDIR/takeover_candidates.txt" 2>/dev/null | wc -l)
    if [[ "$TAKEOVER_COUNT" -gt 0 ]]; then
        ok "Takeover check selesai -> $OUTDIR/takeover_candidates.txt ($TAKEOVER_COUNT baris kandidat, cek manual di $OUTDIR/takeover/*.txt per-tool)"
    else
        ok "Takeover check selesai -> tidak ada kandidat takeover yang terdeteksi dari tools yang tersedia"
    fi
    # Diagnostic: tool mana yang GAK menghasilkan file sama sekali (kemungkinan gagal jalan, bukan cuma "gak nemu apa-apa")
    if [[ -x "$STRATUS_SUBDOMINATOR_BIN" && ! -f "$OUTDIR/takeover/stratus-subdominator_raw.txt" ]]; then
        warn "  -> Subdominator (Stratus-Security) terinstall tapi GAK menghasilkan output sama sekali — cek $OUTDIR/tool_errors_takeover.log bagian [takeover] Subdominator"
    fi
    for tf in subzy_raw.txt nuclei_raw.txt subjack_raw.txt tkosubs_raw.csv dnsreaper_raw.json; do
        tool_name="${tf%_raw*}"
        if command -v "$tool_name" &>/dev/null && [[ ! -f "$OUTDIR/takeover/$tf" ]]; then
            warn "  -> $tool_name terinstall tapi GAK menghasilkan output sama sekali — cek $OUTDIR/tool_errors_takeover.log bagian [takeover] $tool_name"
        fi
    done
else
    warn "Takeover check tidak dijalankan (gagal launch di background)"
fi

if [[ -n "${SECRETS_PID:-}" ]]; then
    log "Menunggu proses JS secret scan (SecretFinder+trufflehog+nuclei) selesai kalau masih jalan..."
    wait "$SECRETS_PID" 2>/dev/null
    SECRETS_COUNT=$(cat "$OUTDIR/secrets_candidates.txt" 2>/dev/null | wc -l)
    if [[ "$SECRETS_COUNT" -gt 0 ]]; then
        ok "Secret scan selesai -> $OUTDIR/secrets_candidates.txt ($SECRETS_COUNT baris kandidat, cek manual di $OUTDIR/secrets/*.txt & js_dump/ per-tool — WASPADA FALSE POSITIVE)"
    else
        ok "Secret scan selesai -> tidak ada token/kredensial yang terdeteksi dari tools yang tersedia"
    fi
    if command -v nuclei &>/dev/null && [[ ! -s "$OUTDIR/secrets/nuclei_raw.txt" ]]; then
        warn "  -> nuclei (secrets) hasilnya 0 byte — kemungkinan templates belum ke-update, cek: nuclei -update-templates"
    fi

    # Extract kandidat endpoint dari JS yang udah didownload run_secret_scan (js_dump/) - hindari download ulang
    if [[ -d "$OUTDIR/js_dump" ]] && [[ -n "$(ls -A "$OUTDIR/js_dump" 2>/dev/null)" ]]; then
        grep -hoE '"(/[a-zA-Z0-9_./-]{2,80})"' "$OUTDIR/js_dump"/*.js 2>/dev/null | tr -d '"' | sort -u > "$OUTDIR/js_endpoints.txt"
        ok "Kandidat endpoint dari JS: $(cat "$OUTDIR/js_endpoints.txt" 2>/dev/null | wc -l) (review manual, dari $(ls "$OUTDIR/js_dump" | wc -l) JS file)"
    else
        touch "$OUTDIR/js_endpoints.txt"
        warn "js_dump/ kosong — gak ada JS yang berhasil didownload, js_endpoints.txt jadi kosong"
    fi
else
    warn "Secret scan tidak dijalankan (gagal launch di background / gak ada JS file)"
fi

# ---------- STAGE 9: SCREENSHOT ----------
stage "Screenshot semua live host (gowitness)"
if command -v gowitness &>/dev/null && [[ -n "$CHROME_BIN" ]]; then
    mkdir -p "$OUTDIR/screenshots"
    (cd "$OUTDIR" && gowitness scan file -f clean_urls_for_screenshot.txt --screenshot-path screenshots/ \
        --chrome-path "$CHROME_BIN" --write-db --write-db-uri "sqlite://$(pwd)/gowitness.sqlite3" \
        --threads "$HTTPX_THREADS" --log-scan-errors 2>/dev/null)
    ok "Screenshot tersimpan di $OUTDIR/screenshots/"
else
    warn "gowitness/browser tidak tersedia, skip screenshot"
fi

# ---------- STAGE 10: SUMMARY REPORT ----------
stage "Generate summary report"
{
    echo "# Recon Summary - $(date '+%Y-%m-%d %H:%M:%S')"
    echo
    echo "Scan mode    : $SCAN_MODE"
    echo "Waktu mulai  : $(date -d "@$SCRIPT_START_EPOCH" '+%Y-%m-%d %H:%M:%S')"
    echo "Waktu selesai: $(date '+%Y-%m-%d %H:%M:%S')"
    echo "Total durasi : $(elapsed_since_start)"
    echo "Target file  : $TARGET_FILE ($TARGET_COUNT domain)"
    echo "Exclude file: $EXCLUDE_FILE ($( [[ -f "$EXCLUDE_FILE" ]] && grep -cve '^\s*$' "$EXCLUDE_FILE" || echo 0) pattern)"
    echo
    echo "## Angka Ringkas"
    echo "- Subdomain hasil enum (in-scope) : $(cat "$OUTDIR/raw_subs.txt" 2>/dev/null | wc -l)"
    echo "- Subdomain valid & resolve        : $(cat "$OUTDIR/resolved_subs.txt" 2>/dev/null | wc -l)"
    echo "- Live host (semua port)           : $(cat "$OUTDIR/live_hosts.txt" 2>/dev/null | wc -l)"
    echo "- Host non-404 (kandidat headless) : $(cat "$OUTDIR/interesting_hosts_all.txt" 2>/dev/null | wc -l)"
    echo "- Katana static URLs               : $(cat "$OUTDIR/katana_static.txt" 2>/dev/null | wc -l)"
    echo "- Katana headless URLs (tambahan)  : $(cat "$OUTDIR/katana_headless.txt" 2>/dev/null | wc -l)"
    echo "- Historical URL (gau)             : $(cat "$OUTDIR/historical_urls.txt" 2>/dev/null | wc -l)"
    echo "- URL dengan parameter             : $(cat "$OUTDIR/urls_with_params.txt" 2>/dev/null | wc -l)"
    echo "- URL kemungkinan API              : $(cat "$OUTDIR/urls_api_like.txt" 2>/dev/null | wc -l)"
    echo "- URL ekstensi sensitif            : $(cat "$OUTDIR/urls_sensitive_ext.txt" 2>/dev/null | wc -l)"
    echo "- JS files ditemukan               : $(cat "$OUTDIR/js_files.txt" 2>/dev/null | wc -l)"
    echo "- Kandidat endpoint dari JS        : $(cat "$OUTDIR/js_endpoints.txt" 2>/dev/null | wc -l)"
    echo "- URL gabungan setelah dedup       : $(cat "$OUTDIR/all_urls_normalized.txt" 2>/dev/null | wc -l)"
    echo "- Kandidat subdomain takeover      : $(cat "$OUTDIR/takeover_candidates.txt" 2>/dev/null | wc -l)"
    echo "- Kandidat token/secret di JS       : $(cat "$OUTDIR/secrets_candidates.txt" 2>/dev/null | wc -l)"
    echo "- AXFR zone transfer terbuka (ACTIVE) : $(( $(cat "$OUTDIR/axfr_results.txt" 2>/dev/null | grep -c 'TERBUKA') ))"
    echo
    echo "## Host dengan status code non-404/301 standar (worth di-review)"
    grep -Ev '\[404( |\])|\[301' "$OUTDIR/live_hosts.txt" 2>/dev/null | head -30 || echo "(tidak ada data)"
    echo
    if [[ -s "$OUTDIR/axfr_results.txt" ]]; then
        echo "## 🚨 ZONE TRANSFER (AXFR) TERBUKA — CRITICAL, laporkan segera!"
        cat "$OUTDIR/axfr_results.txt"
        echo
    fi
    if [[ -s "$OUTDIR/takeover_candidates.txt" ]]; then
        echo "## ⚠️  KANDIDAT SUBDOMAIN TAKEOVER (PRIORITAS TINGGI, cek manual dulu sebelum lapor!)"
        cat "$OUTDIR/takeover_candidates.txt"
        echo
    fi
    if [[ -s "$OUTDIR/secrets_candidates.txt" ]]; then
        echo "## ⚠️  KANDIDAT TOKEN/SECRET DI JS (PRIORITAS TINGGI, VERIFIKASI dulu — rawan false positive!)"
        cat "$OUTDIR/secrets_candidates.txt"
        echo
    fi
    echo "## Langkah Selanjutnya (manual, sesuai ROE program)"
    echo "1. Review live_hosts.txt & screenshots/ -> pilih target prioritas"
    echo "2. Review urls_sensitive_ext.txt, urls_api_like.txt, js_endpoints.txt manual"
    echo "3. Cek arjun_results.txt utk parameter tersembunyi"
    echo "4. Cek takeover_candidates.txt & takeover/*.txt manual -> verifikasi tiap kandidat SEBELUM submit (banyak false positive)"
    echo "5. nuclei manual rate-limit rendah:"
    echo "   nuclei -l $OUTDIR/live_hosts.txt -t exposures/,misconfiguration/ -rl 10 -o $OUTDIR/nuclei_results.txt"
    echo "6. Fokus manual testing: business logic (race condition), IDOR, auth/OAuth flow"
} > "$OUTDIR/report.md"
ok "Summary report -> $OUTDIR/report.md"

